    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#ClosedDiagonal -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#ClosedDiagonal">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Diagonal"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasSquare"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Square"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasPiece"/>
                                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Pawn"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Diagonal"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#OpenDiagonal"/>
    </owl:Class>
    



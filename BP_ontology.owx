    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#underAttack -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#underAttack"/>
    


